# ============================================================
#  IFSA Server — Environment Variables
#  
#  SETUP:
#  1. Copy this file:   cp .env.example .env
#  2. Fill in values below
#  3. Add .env to .gitignore (NEVER commit this file!)
#  4. Run server:       node server.js
# ============================================================

# Server port (default: 3000)
PORT=3000

# JWT secret key — generate with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_STRING

# Admin password hash — generate with:
# node change-password.js
ADMIN_PASSWORD_HASH=REPLACE_WITH_BCRYPT_HASH

# MIGRATION: frontend/backend split — used for CORS so the backend only
# accepts requests from the deployed frontend origin (see Section 5 of
# the migration plan).
FRONTEND_URL=https://ifsaacademy.in
